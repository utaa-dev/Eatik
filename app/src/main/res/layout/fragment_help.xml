<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Judul Fragment -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_help"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <!-- Section Panduan -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/short_guide"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fill_in_the_guide"
            android:textSize="16sp"
            android:paddingBottom="16dp"/>

        <!-- Section FAQ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/faq"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/frequently_asked_questions"
            android:textSize="16sp"
            android:paddingBottom="16dp"/>

        <!-- Section Kontak Support -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kontak Support"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <Button
            android:id="@+id/btn_email_support"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/email_to_support"
            android:onClick="onEmailSupportClicked"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_whatsapp_support"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chat_via_whatsapp"
            android:onClick="onWhatsAppSupportClicked"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>