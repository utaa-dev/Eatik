<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_controller"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.eatik.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_searchMenuFragment"
            />
    </fragment>
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.eatik.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_aboutFragment"
            app:destination="@id/aboutFragment" />
        <action
            android:id="@+id/action_profileFragment_to_helpFragment"
            app:destination="@id/helpFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>
    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.example.eatik.ui.CategoryFragment"
        android:label="Category"
        tools:layout="@layout/fragment_category" />
    <fragment
        android:id="@+id/orderFragment"
        android:name="com.example.eatik.ui.OrderFragment"
        android:label="Order"
        tools:layout="@layout/fragment_order" />
    <fragment
        android:id="@+id/spaceFragment"
        android:name="com.example.eatik.data.ui.SpaceFragment"
        android:label="Space"
        tools:layout="@layout/fragment_space" />
    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.example.eatik.ui.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />
    <fragment
        android:id="@+id/helpFragment"
        android:name="com.example.eatik.ui.HelpFragment"
        android:label="Help"
        tools:layout="@layout/fragment_help" />
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.eatik.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/makananFragment"
        android:name="com.example.eatik.ui.MakananFragment"
        android:label="Makanan"
        tools:layout="@layout/fragment_makanan" />
    <fragment
        android:id="@+id/minumanFragment"
        android:name="com.example.eatik.ui.MinumanFragment"
        android:label="Minuman"
        tools:layout="@layout/fragment_minuman" />
    <fragment
        android:id="@+id/detailMenuFragment"
        android:name="com.example.eatik.data.ui.DetailMenuFragment"
        android:label="DetailMenuFragment" />
</navigation>